# ============================================
# GuardianSync v2.0 - API Gateway Environment
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit the actual .env file to version control

# ============================================
# Server Configuration
# ============================================
NODE_ENV=development
PORT=3000
API_VERSION=v1

# ============================================
# Database Configuration
# ============================================
# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/guardiansync

# Redis configuration (optional - for scaling)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ============================================
# JWT Authentication
# ============================================
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-token-secret-change-in-production
JWT_REFRESH_EXPIRES_IN=30d

# ============================================
# AI Service Configuration
# ============================================
# URL of the Python face recognition service
AI_SERVICE_URL=http://localhost:8001
AI_SERVICE_TIMEOUT=30000

# ============================================
# Cloud Storage (Choose one)
# ============================================
# AWS S3 Configuration
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=guardiansync-photos

# OR Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ============================================
# Real-Time Configuration
# ============================================
# Socket.io CORS origins (comma-separated)
SOCKET_CORS_ORIGINS=http://localhost:5173,http://localhost:3001

# Location update throttle in milliseconds
LOCATION_UPDATE_THROTTLE_MS=5000

# ============================================
# Security
# ============================================
# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3001

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# Logging
# ============================================
LOG_LEVEL=debug
LOG_FORMAT=combined

# ============================================
# Email/SMS Notifications (Feature #2)
# ============================================
# Enable/disable notification channels
EMAIL_ENABLED=false
SMS_ENABLED=false

# Email provider: 'smtp' or 'sendgrid'
EMAIL_PROVIDER=smtp
EMAIL_FROM=GuardianSync <noreply@guardiansync.com>

# SMTP Configuration (for Gmail, Outlook, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# SendGrid Configuration (alternative to SMTP)
SENDGRID_API_KEY=

# Twilio SMS Configuration
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1234567890

# Notification preferences
# Which scan types trigger notifications (comma-separated)
NOTIFICATION_SCAN_TYPES=morning_pickup,morning_dropoff,evening_pickup,evening_dropoff
# Retry settings for failed notifications
NOTIFICATION_RETRY_ATTEMPTS=3
NOTIFICATION_RETRY_DELAY_MS=5000

# ============================================
# Absentee Auto-Detection (Feature #3)
# ============================================
# Enable/disable auto-detection
ABSENTEE_DETECTION_ENABLED=true

# Cron schedule (format: second minute hour dayOfMonth month dayOfWeek)
# Default: 9:30 AM on weekdays
ABSENTEE_CRON_SCHEDULE=0 30 9 * * 1-5

# Timezone for cron jobs
ABSENTEE_TIMEZONE=America/New_York

# Cutoff times for determining absence
MORNING_PICKUP_CUTOFF=08:30
MORNING_DROPOFF_CUTOFF=09:30

# Filter by specific buses (comma-separated IDs) or 'all'
ABSENTEE_BUS_FILTER=all

# Notify parents when student is auto-marked absent
ABSENTEE_NOTIFY_PARENTS=true

# Send daily absence report to admin
ABSENTEE_NOTIFY_ADMIN=false
ABSENTEE_ADMIN_EMAIL=admin@school.com

# Daily status reset (reset all students to 'not_boarded')
DAILY_RESET_ENABLED=true
DAILY_RESET_CRON=0 0 5 * * 1-5
